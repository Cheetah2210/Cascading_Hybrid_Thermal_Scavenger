# ==============================================================================
# CHTS Repository Git Ignore Rules
# ==============================================================================

# Python Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# Local Virtual Environments (Prevent pushing massive external binaries)
.venv/
venv/
ENV/
env/
ActiveState.venv/

# Python packaging and distribution build outputs
build/
dist/
downloads/
eggs/
.eggs/
*.egg-info/
*.egg

# Testing and Coverage
.pytest_cache/
.coverage
htmlcov/
*.log

# IDEs, Editors, and OS-specific metadata
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db
